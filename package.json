{
  "name": "amm-v2",
  "version": "1.0.0",
  "description": "AMM V2 - Automated Market Maker with Factory and Router",
  "main": "index.js",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
